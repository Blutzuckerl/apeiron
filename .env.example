HOST=0.0.0.0
PORT=3000
HTTP_PORT=3000
HTTPS_PORT=3443
HTTPS_ENABLED=1
FORCE_HTTPS=0
FORCE_HTTPS_ALLOW_LOCALHOST=1
HTTPS_REDIRECT_PORT=3443
VOICE_REQUIRE_SECURE_ORIGIN=1
VOICE_REQUIRE_TURN=1
TRUST_PROXY=0
TLS_MODE=self-signed
TLS_CERT=
TLS_KEY=
LAN_PUBLIC_HTTPS_URL=
APEIRON_PUBLIC_BASE_URL=
TLS_SELF_SIGNED_CERT=data/certs/apeiron-selfsigned-cert.pem
TLS_SELF_SIGNED_KEY=data/certs/apeiron-selfsigned-key.pem
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=turn:<LAN-IP>:3478?transport=udp,turn:<LAN-IP>:3478?transport=tcp
TURN_USER=apeiron
TURN_PASS=replace-with-turn-secret
SESSION_SECRET=replace-with-long-random-secret
JWT_SECRET=replace-with-long-random-secret
LLM_PROVIDER=auto
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=10000
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=60000
