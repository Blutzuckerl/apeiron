<%- include('../partials/head', { title }) %>
<main class="auth-page">
  <section class="auth-card gradient-card floaty">
    <h1>Passwort vergessen</h1>
    <p class="sub">Wir erzeugen einen sicheren Reset-Link</p>
    <%- include('../partials/flash') %>

    <form method="post" action="/forgot-password" class="auth-form">
      <label>Email oder Username
        <input type="text" name="identifier" required />
      </label>
      <button class="btn primary" type="submit">Reset-Link generieren</button>
    </form>

    <div class="auth-links">
      <a href="/login">Zurück zum Login</a>
    </div>

    <%- include('../partials/cat-states') %>
  </section>
</main>
<%- include('../partials/tail') %>
