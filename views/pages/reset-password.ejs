<%- include('../partials/head', { title }) %>
<main class="auth-page">
  <section class="auth-card gradient-card floaty">
    <h1>Passwort zurücksetzen</h1>
    <p class="sub">Token: <code><%= token %></code></p>
    <%- include('../partials/flash') %>

    <form method="post" action="/reset-password/<%= token %>" class="auth-form">
      <label>Neues Passwort
        <input type="password" name="password" required />
      </label>
      <button class="btn primary" type="submit">Passwort aktualisieren</button>
    </form>

    <div class="auth-links">
      <a href="/login">Zum Login</a>
    </div>

    <%- include('../partials/cat-states') %>
  </section>
</main>
<%- include('../partials/tail') %>
